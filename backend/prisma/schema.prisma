generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Network {
  SEPOLIA
}

enum Token {
  ETH
}

enum ResourceType {
  IMAGE
  VIDEO
  LINK
}

enum TransactionStatus {
  PENDING
  SETTLED
  REFUND_REQUESTED
  REFUNDED
}

// User: Ethereum wallet-authenticated users (merchants)
model User {
  id              String        @id @default(uuid())
  walletAddress   String        @unique
  displayName     String?
  shieldedAddress String?       // Chainlink Private Token shielded address
  lastLogin       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  resources       Resource[]
  transactions    Transaction[]
}

// AuthChallenge: Short-lived nonces for SIWE (Sign-In With Ethereum)
model AuthChallenge {
  id            String   @id @default(uuid())
  walletAddress String
  nonce         String   @unique
  expiresAt     DateTime
  used          Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([walletAddress])
}

// Resource: Data assets owned by users
model Resource {
  id                  String        @id @default(uuid())
  userId              String
  user                User          @relation(fields: [userId], references: [id])
  title               String
  description         String?
  type                ResourceType
  price               Float         @default(0)
  url                 String?
  imageData           String?       @db.Text
  network             Network       @default(SEPOLIA)
  token               Token         @default(ETH)
  isActive            Boolean       @default(true)
  autoApprovalMinutes Int           @default(60)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  transactions        Transaction[]

  @@index([userId])
}

// Transaction: Escrow records for x402 payments
model Transaction {
  id                     String            @id @default(uuid())
  userId                 String
  user                   User              @relation(fields: [userId], references: [id])
  resourceId             String?
  resource               Resource?         @relation(fields: [resourceId], references: [id])
  agentId                String            // Agent wallet or shielded address
  amount                 Float
  network                Network           @default(SEPOLIA)
  token                  Token             @default(ETH)
  status                 TransactionStatus @default(PENDING)
  receiptCode            String            @unique @default(uuid())
  autoSettleAt           DateTime?
  expiryAt               DateTime
  paymentTransactionId   String?           // Private Token API transaction_id
  paymentHeader          String?           @db.Text
  encryptedDisputeReason String?
  aiDecision             String?           // 'AI_VALID', 'AI_INVALID'
  aiReasoning            String?           @db.Text
  aiConfidence           Int?              // 0-100
  merchantExplanation    String?           @db.Text
  aiAnalyzedAt           DateTime?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  @@index([userId])
  @@index([resourceId])
  @@index([autoSettleAt])
}
